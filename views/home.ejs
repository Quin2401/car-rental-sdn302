<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Car Rental System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container mt-5">
    <h1 class="mb-4 text-primary">Car Rental Management</h1>

    <h3>Available Cars</h3>
    <table class="table table-bordered mb-5">
        <thead class="table-dark">
            <tr>
                <th>Car Number</th>
                <th>Capacity</th>
                <th>Price/Day</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            <% cars.forEach(car => { %>
                <tr>
                    <td><%= car.carNumber %></td>
                    <td><%= car.capacity %> seats</td>
                    <td><%= car.pricePerDay.toLocaleString() %> VND</td>
                    <td>
                        <a href="/book/<%= car.carNumber %>" class="btn btn-success btn-sm">Book Now</a>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>

    <h3>Booking History</h3>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Customer Name</th>
                <th>Car Number</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th>Total Amount</th>
            </tr>
        </thead>
        <tbody>
            <% bookings.forEach(b => { %>
                <tr>
                    <td><%= b.customerName %></td>
                    <td><%= b.carNumber %></td>
                    <td><%= new Date(b.startDate).toLocaleDateString() %></td>
                    <td><%= new Date(b.endDate).toLocaleDateString() %></td>
                    <td><strong class="text-danger"><%= b.totalAmount.toLocaleString() %> VND</strong></td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</body>
</html>