<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Book Car <%= car.carNumber %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container mt-5">
    <div class="card shadow" style="max-width: 500px; margin: auto;">
        <div class="card-header bg-primary text-white">
            <h4>Book Car: <%= car.carNumber %></h4>
        </div>
        <div class="card-body">
            <% if (error) { %>
                <div class="alert alert-danger"><%= error %></div>
            <% } %>

            <form action="/book" method="POST">
                <div class="mb-3">
                    <label>Customer Name</label>
                    <input type="text" name="customerName" class="form-control" required>
                </div>
                <div class="mb-3">
                    <label>Car Number</label>
                    <input type="text" name="carNumber" class="form-control" value="<%= car.carNumber %>" readonly>
                </div>
                <div class="mb-3">
                    <label>Start Date</label>
                    <input type="date" name="startDate" class="form-control" required>
                </div>
                <div class="mb-3">
                    <label>End Date</label>
                    <input type="date" name="endDate" class="form-control" required>
                </div>
                <button type="submit" class="btn btn-primary w-100">Confirm Booking</button>
                <a href="/" class="btn btn-secondary w-100 mt-2">Cancel</a>
            </form>
        </div>
    </div>
</body>
</html>